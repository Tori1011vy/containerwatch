{
  "title": "ContainerWatch - Overview",
  "uid": "containerwatch-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Sample App Status",
      "targets": [
        {
          "expr": "up{job=\"sample-app\"}"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Host CPU %",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "targets": [
        {
          "expr": "sum(rate(containerwatch_http_requests_total[1m])) by (status)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      }
    },
    {
      "type": "timeseries",
      "title": "Application p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(containerwatch_http_request_duration_seconds_bucket[5m])))"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "type": "timeseries",
      "title": "Container Memory",
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{name!=\"\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      }
    }
  ]
}
